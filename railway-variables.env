# Railway 环境变量配置模板
# 使用方法：
# 1. 复制此文件到 Railway 项目根目录
# 2. 在 Railway Dashboard 中导入这些环境变量
# 3. 或使用 Railway CLI: railway variables set --env <environment> < <file>

# =============================================
# 后端环境变量 (Backend Environment Variables)
# =============================================

# 数据库配置 (Railway PostgreSQL 会自动提供，以下为示例)
SPRING_DATASOURCE_URL=jdbc:postgresql://host:port/database
SPRING_DATASOURCE_USERNAME=username
SPRING_DATASOURCE_PASSWORD=password
SPRING_JPA_HIBERNATE_DDL_AUTO=validate

# 服务器配置
SERVER_PORT=8080

# CORS 配置 - 请替换为你的前端域名
APP_CORS_ALLOWED_ORIGINS=https://your-frontend.railway.app,http://localhost:5173

# 存储配置
APP_STORAGE_BLOB_ENDPOINT=https://blob.vercel-blob.com

# 日志配置
LOG_LEVEL_APP=INFO
LOG_LEVEL_HIBERNATE_SQL=WARN
LOG_LEVEL_HIBERNATE_BINDER=WARN

# =============================================
# 前端环境变量 (Frontend Environment Variables)
# =============================================

# API 后端地址 - 请替换为你的后端域名
VITE_API_URL=https://your-backend.railway.app/api

# =============================================
# 使用说明
# =============================================

# 方法 1: Railway Dashboard
# 1. 进入项目 > Variables
# 2. 点击 "Add Variable"
# 3. 手动添加上述变量

# 方法 2: Railway CLI
# cd backend/machrio-api
# railway variables set SPRING_DATASOURCE_URL="..." SERVER_PORT=8080 ...

# 方法 3: 使用 .env 文件
# 在 Railway Dashboard 中上传 .env 文件
