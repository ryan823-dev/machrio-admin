# Railway 环境变量配置示例
# 请在 Railway 控制面板中设置以下环境变量

# =============================================
# 数据库配置 (Railway PostgreSQL)
# =============================================
# Railway 会自动注入 DATABASE_URL，格式：postgresql://user:password@host:port/database
# application.yml 会自动从 DATABASE_URL 读取
DATABASE_URL=postgresql://user:password@host:5432/database

# =============================================
# 后端配置
# =============================================
SERVER_PORT=8080
APP_CORS_ALLOWED_ORIGINS=https://your-frontend.railway.app,http://localhost:5173
APP_STORAGE_BLOB_ENDPOINT=https://blob.vercel-blob.com

# =============================================
# 前端配置
# =============================================
VITE_API_URL=https://your-backend.railway.app/api
