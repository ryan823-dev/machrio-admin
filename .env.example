# =============================================
# Machrio Admin 环境变量配置示例
# =============================================
# 复制此文件为 .env 并填入实际值
# =============================================

# ---------------------------------------------
# 数据库配置
# ---------------------------------------------
# 数据库密码（生产环境请使用强密码）
DB_PASSWORD=your-strong-password-here

# 如使用外部数据库（阿里云 RDS），取消注释并配置
# SPRING_DATASOURCE_URL=jdbc:postgresql://your-rds-endpoint:5432/machrio_admin
# SPRING_DATASOURCE_USERNAME=your-rds-username
# SPRING_DATASOURCE_PASSWORD=your-rds-password

# ---------------------------------------------
# JWT 认证配置
# ---------------------------------------------
# 生产环境必须修改！至少 32 个字符
JWT_SECRET=your-super-secret-production-key-change-this-please

# ---------------------------------------------
# CORS 配置
# ---------------------------------------------
# 允许的源域名（逗号分隔）
CORS_ORIGINS=https://admin.machrio.com,https://machrio.com,http://localhost:5173

# ---------------------------------------------
# 阿里云 OSS 配置
# ---------------------------------------------
# OSS 端点（根据地域修改）
OSS_ENDPOINT=https://oss-cn-hangzhou.aliyuncs.com

# AccessKey（在 RAM 控制台创建）
OSS_ACCESS_KEY_ID=LTAI5txxxxxxx
OSS_ACCESS_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# Bucket 名称
OSS_BUCKET=machrio-admin

# ---------------------------------------------
# 前端配置
# ---------------------------------------------
# API 地址（生产环境）
VITE_API_URL=https://api.machrio.com/api

# ---------------------------------------------
# 日志配置（可选）
# ---------------------------------------------
LOG_LEVEL_APP=INFO
LOGGING_LEVEL_ROOT=INFO

# ---------------------------------------------
# 服务器配置（可选）
# ---------------------------------------------
SERVER_PORT=8080

# ---------------------------------------------
# 存储配置（可选）
# ---------------------------------------------
APP_STORAGE_BLOB_ENDPOINT=https://blob.vercel-blob.com
